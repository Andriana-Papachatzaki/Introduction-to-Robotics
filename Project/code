def get_screw_axes(robotId, joint_indices):
    S_list = []
    for joint_idx in joint_indices:
        # Λήψη πληροφοριών άρθρωσης
        info = p.getJointInfo(robotId, joint_idx)
        joint_axis_local = np.array(info[11])
        
        # Λήψη κατάστασης του link (World Frame)
        # Χρησιμοποιούμε το link state για να βρούμε την τρέχουσα θέση q και τον άξονα ω
        state = p.getLinkState(robotId, joint_idx, computeForwardKinematics=True)
        pos_world = np.array(state[4]) # World link frame position (q)
        orn_world = state[5]           # World link frame orientation
        
        # Μετατροπή του τοπικού άξονα (jointAxis) στο World Frame
        rot_matrix = np.reshape(p.getMatrixFromQuaternion(orn_world), (3, 3))
        omega = rot_matrix @ joint_axis_local
        
        # Υπολογισμός v = -omega x q
        v = np.cross(-omega, pos_world)
        
        S = np.concatenate([omega, v])
        S_list.append(S)
        
    return np.column_stack(S_list)

