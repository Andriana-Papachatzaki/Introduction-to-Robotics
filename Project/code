#Μετατροπή Twist σε πίνακα 4x4
def TwistToMatrix(V):
    w = V[0:3]
    v = V[3:6]
    return np.block([[skew(w), v.reshape(3,1)], [np.zeros((1,3)), np.array([[1]])]])

#Δημιουργία εκθετικού πίνακα
def MatrixExp(v_hat, theta):
    w_hat = v_hat[:3, :3]
    v = v_hat[:3, 3]
    if np.allclose(w_hat,0):
        R = np.eye(3)
        p = v * theta
    else:
        R = np.eye(3) + np.sin(theta) * w_hat + (1 - np.cos(theta)) * (w_hat @ w_hat)
        p = (np.eye(3) * theta + (1 - np.cos(theta)) * w_hat + (theta - np.sin(theta)) * (w_hat @ w_hat)) @ v
    return np.block([[R, p.reshape(3,1)], [np.zeros((1,3)), np.array([[1]])]])

#Δημιουργία λογαριθμικού πίνακα
def MatrixLog(T):
    R = T[:3,:3]
    p = T[:3,3]
    if np.allclose(R, np.eye(3)):
        return np.concatenate([np.zeros(3), p])
    else:
        tr = np.trace(R)
        theta = np.arccos(np.clip((tr - 1)/2, -1.0, 1.0))
        if np.abs(theta) < 1e-10:
            w = np.zeros(3)
        else:
            w = (1/(2*np.sin(theta))) * np.array([R[2,1]-R[1,2], R[0,2]-R[2,0], R[1,0]-R[0,1]])
        W = skew(w)
        if np.abs(theta) < 1e-10:
            v = p.copy()
        else:
            G_inv = (np.eye(3)/theta - 0.5*W + (1/theta - 0.5/np.tan(theta/2)) * (W @ W))
            v = G_inv @ p
        return np.concatenate([w * theta, v * theta])
    
#Υπολογισμός Adjoint πίνακα
def Ad(T):
    R = T[:3,:3]
    p = T[:3,3]
    AdT = np.zeros((6,6))
    AdT[:3,:3] = R
    AdT[3:,:3] = skew(p) @ R
    AdT[3:,3:] = R
    return AdT    

#Υπολογισμός των forward kinematics
def ForwardKinematics(vlist, thetas, M):
    T = np.eye(4)
    for i in range(len(thetas)):
        S_hat = TwistToMatrix(vlist[:,i])
        T = T @ MatrixExp(S_hat, thetas[i])
    return T @ M

#Υπολογισμός Space Jacobian
def SpaceJacobian(vlist, thetas):
    n = len(thetas)
    Js = np.zeros((6,n))
    T = np.eye(4)
    for i in range(n):
        Js[:,i] = Ad(T) @ vlist[:,i]
        S_hat = TwistToMatrix(vlist[:,i])
        T = T @ MatrixExp(S_hat, thetas[i])
    return Js

#Υπολογισμός Inverse Kinematics
def InvKinNewton(vlist, M, dest, theta0, tol=1e-4, max_iter=3000, lamb=0.1, max_step=0.5):
    theta = theta0.copy().astype(float)
    for it in range(max_iter):
        T_current = ForwardKinematics(vlist, theta, M)
        T_error = inv(T_current) @ dest
        V_b = MatrixLog(T_error)
        error_norm = norm(V_b)
        
        if error_norm < tol:
            print(f"Converged in {it} iterations, error {error_norm:.3e}")
            return theta
        
        Js = SpaceJacobian(vlist, theta)
        Jb = Ad(inv(T_current)) @ Js
        JJt = Jb @ Jb.T
        lamI = (lamb**2) * np.eye(6)
        inv_term = np.linalg.inv(JJt + lamI)
        dtheta = Jb.T @ (inv_term @ V_b)
        
        if norm(dtheta) > max_step:
            dtheta = dtheta * (max_step / norm(dtheta))
        theta = theta + dtheta

        for j in range(len(theta)):
            theta[j] = np.clip(theta[j],
            joint_limits[j][0],
            joint_limits[j][1])

    print("Max iterations reached, final error:", error_norm)
    return theta

