def create_fixed_wall_with_rotated_hole(position):
    color = [0.8, 0.6, 0.8, 0.7]
    W = 0.1    
    H = 0.1    
    T = 0.025 
    gap = hole_size * np.sqrt(2) 

    # Πάνω κομμάτι
    p.createMultiBody(0, 
        p.createCollisionShape(p.GEOM_BOX, halfExtents=[T, W, (H-gap)/2]),
        p.createVisualShape(p.GEOM_BOX, halfExtents=[T, W, (H-gap)/2], rgbaColor=color),
        basePosition=[position[0], position[1], position[2] + (gap + (H-gap)/2)])

    # Κάτω κομμάτι
    p.createMultiBody(0, 
        p.createCollisionShape(p.GEOM_BOX, halfExtents=[T, W, (H-gap)/2]),
        p.createVisualShape(p.GEOM_BOX, halfExtents=[T, W, (H-gap)/2], rgbaColor=color),
        basePosition=[position[0], position[1], position[2] - (gap + (H-gap)/2)])

    # Αριστερό κομμάτι (ενδιάμεσο ύψος)
    p.createMultiBody(0, 
        p.createCollisionShape(p.GEOM_BOX, halfExtents=[T, (W-gap)/2, gap]),
        p.createVisualShape(p.GEOM_BOX, halfExtents=[T, (W-gap)/2, gap], rgbaColor=color),
        basePosition=[position[0], position[1] - (gap + (W-gap)/2), position[2]])

    # Δεξί κομμάτι (ενδιάμεσο ύψος)
    p.createMultiBody(0, 
        p.createCollisionShape(p.GEOM_BOX, halfExtents=[T, (W-gap)/2, gap]),
        p.createVisualShape(p.GEOM_BOX, halfExtents=[T, (W-gap)/2, gap], rgbaColor=color),
        basePosition=[position[0], position[1] + (gap + (W-gap)/2), position[2]])

