#Συνάρτηση για την δημιουργία πίνακα μετασχηματισμού.
def T(R, t):
    T = np.eye(4)
    T[:3, :3], T[:3, 3] = R, t 
    return T

# Συνάρτηση περιστροφής κατά τον άξονα x.
def Rx(deg):
    theta = np.deg2rad(deg)
    c, s = np.cos(theta), np.sin(theta)
    Rx = np.array([[1, 0, 0],
                   [0, c, -s],
                   [0, s, c]])
    return Rx

